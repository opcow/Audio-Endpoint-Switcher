{
            "version": "2.0.0",
            "tasks": [
                {
                    "label": "Build All",
                    "type": "shell",
                    "command": "${workspaceFolder}\\build-all.bat",
                    "options": {
                        "cwd": "${workspaceFolder}",
                        "shell": {
                            "executable": "cmd.exe",
                            "args": ["/d", "/c"]
                        }
                    },
                    "group": {
                        "kind": "build",
                        "isDefault": true
                    },
                    "problemMatcher": "$msCompile"
                },
                {
                    "label": "Build Debug",
                    "type": "shell",
                    "command": "${workspaceFolder}\\build-debug.bat",
                    "options": {
                        "cwd": "${workspaceFolder}",
                        "shell": {
                            "executable": "cmd.exe",
                            "args": ["/d", "/c"]
                        }
                    },
                    "group": {
                        "kind": "build",
                        "isDefault": false
                    },
                    "problemMatcher": "$msCompile"
                },
                {
                    "label": "Build Release",
                    "type": "shell",
                    "command": "${workspaceFolder}\\build-release.bat",
                    "options": {
                        "cwd": "${workspaceFolder}",
                        "shell": {
                            "executable": "cmd.exe",
                            "args": ["/d", "/c"]
                        }
                    },
                    "group": {
                        "kind": "build",
                        "isDefault": false
                    },
                    "problemMatcher": "$msCompile"
                },
                {
                    "label": "Clean",
                    "type": "shell",
                    "command": "${workspaceFolder}\\build-clean.bat",
                    "options": {
                        "cwd": "${workspaceFolder}",
                        "shell": {
                            "executable": "cmd.exe",
                            "args": ["/d", "/c"]
                        }
                    },
                    "problemMatcher": "$msCompile"
                }
            ]
        }